# Node
NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:5173
TRUSTED_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bht_nexus

# Better Auth
BETTER_AUTH_SECRET=your-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend (Email)
RESEND_API_KEY=your-resend-api-key
SENDER_EMAIL=noreply@example.com

# Contact
CONTACT_NAME=Your Name
CONTACT_WHATSAPP=https://wa.me/6281234567890
CONTACT_EMAIL=contact@example.com

# Rate Limiting (Global)
RATE_LIMIT_GLOBAL_WINDOW_MINUTES=15
RATE_LIMIT_GLOBAL_MAX=100
# Rate Limiting (Auth)
RATE_LIMIT_AUTH_WINDOW_MINUTES=15
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_SIGNIN_WINDOW_MINUTES=15
RATE_LIMIT_SIGNIN_MAX=10
RATE_LIMIT_SIGNUP_WINDOW_MINUTES=60
RATE_LIMIT_SIGNUP_MAX=5
RATE_LIMIT_OTP_REQ_WINDOW_MINUTES=15
RATE_LIMIT_OTP_REQ_MAX=5
RATE_LIMIT_OTP_VERIFY_WINDOW_MINUTES=15
RATE_LIMIT_OTP_VERIFY_MAX=10
RATE_LIMIT_RESET_PWD_WINDOW_MINUTES=15
RATE_LIMIT_RESET_PWD_MAX=5
RATE_LIMIT_DELETE_ACC_WINDOW_MINUTES=15
RATE_LIMIT_DELETE_ACC_MAX=3
RATE_LIMIT_CHANGE_PWD_WINDOW_MINUTES=15
RATE_LIMIT_CHANGE_PWD_MAX=5
RATE_LIMIT_MEDIA_UPLOAD_WINDOW_MINUTES=15
RATE_LIMIT_MEDIA_UPLOAD_MAX=20

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=bht-nexus
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Media Upload
MEDIA_UPLOAD_MAX_SIZE_MB=10
MEDIA_UPLOAD_MAX_RAW_SIZE_MB=50
MEDIA_UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,mp4,pdf,doc,docx

# Upstash Redis (Rate Limiting / Caching)
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token
UPSTASH_REDIS_URL=redis://default:password@xxxxx.upstash.io:6379

# Cron
CRON_SECRET=your-cron-secret

# Session
SESSION_EXPIRES_IN=604800
SESSION_UPDATE_AGE=86400
SESSION_COOKIE_CACHE_ENABLED=true
SESSION_COOKIE_CACHE_MAX_AGE=300
