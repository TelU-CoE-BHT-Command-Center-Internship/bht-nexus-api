{
  "name": "bht-nexus-api",
  "version": "0.0.1",
  "description": "Backend API dan orkestrasi otomasi untuk BHT-Nexus.",
  "author": "TelU CoE BHT Command Center Internship",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=11.0.0 <12.0.0"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"{src,test}/**/*.ts\" \"test/*.json\" \".github/workflows/*.yml\" \".github/dependabot.yml\" \".vscode/*.json\" \"*.{json,mjs}\" \".prettierrc\" \"lefthook.yml\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\" \"test/*.json\" \".github/workflows/*.yml\" \".github/dependabot.yml\" \".vscode/*.json\" \"*.{json,mjs}\" \".prettierrc\" \"lefthook.yml\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "hooks:install": "lefthook install",
    "hooks:validate": "lefthook validate",
    "hooks:run:pre-commit": "lefthook run pre-commit --force",
    "hooks:run:pre-push": "lefthook run pre-push --force",
    "check:commit": "npm run format:check && npm run lint && npm run typecheck",
    "check:push": "npm run test:unit && npm run test:e2e && npm run build",
    "check": "npm run check:commit && npm run check:push"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "lefthook": "2.1.10",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "allowScripts": {
    "lefthook@2.1.10": true,
    "unrs-resolver": false
  }
}
